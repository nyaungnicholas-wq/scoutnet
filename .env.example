# Copy to .env.local. Everything is optional in development — with no env at all,
# the app runs on an embedded local Postgres (PGlite, stored in .data/), discovery
# runs on free OpenStreetMap + sample data, and emails land in the in-app outbox
# (/dashboard/outbox) instead of real inboxes. Zero setup to see the whole loop.

# REQUIRED in production. Encrypts stored sender API keys and signs
# unsubscribe tokens. Generate one: openssl rand -base64 32
APP_SECRET=

# Production Postgres (e.g. Neon). Unset = embedded PGlite in .data/
DATABASE_URL=

# OPTIONAL. Unlocks the "Google Places" discovery source — the richest local data
# (ratings, review counts, websites, phone). Without it, ScoutNet still finds real
# businesses via OpenStreetMap (free, no key) and can run on sample data.
# Get one: console.cloud.google.com → enable "Places API (New)" → create an API key.
GOOGLE_PLACES_API_KEY=

# OPTIONAL. Unlocks the AI owner-finder — reads each business's About/Team page and
# pulls the owner's first name WITH the exact sentence as evidence (far higher
# coverage + precision than the free regex engine). Without it, owner-finding falls
# back to credentialed business-name parsing only. The SAME key as GOOGLE_PLACES_API_KEY
# works here once you enable the "Gemini API" on that Google Cloud project
# (console.cloud.google.com → APIs → enable "Generative Language API"); otherwise set a
# dedicated key. If GEMINI_API_KEY is unset, the app reuses GOOGLE_PLACES_API_KEY.
GEMINI_API_KEY=

# Platform email (Resend) — TRANSACTIONAL ONLY. Used exclusively for magic-link
# sign-in and address-verification emails from the one platform domain.
# Outreach NEVER sends through this key: every owner connects their own Resend
# key + verified domain in Settings (encrypted at rest with APP_SECRET).
RESEND_API_KEY=
PLATFORM_FROM="ScoutNet <hello@your-verified-domain.com>"

# Absolute base URL, used to build unsubscribe links when the dispatcher runs
# from cron (no request origin). e.g. https://app.scoutnet.example
APP_BASE_URL=

# Secret the Vercel cron presents to /api/cron/dispatch. Required in production;
# in dev the dispatch endpoint is open so the loop is testable with zero config.
CRON_SECRET=

# OPTIONAL. Email verification before send — protects your sending reputation by
# dropping catch-all / invalid addresses so they never bounce. Without a key,
# ScoutNet uses a deterministic demo verifier in dev (no real checks). Set ONE:
# NEVERBOUNCE_API_KEY=
# ZEROBOUNCE_API_KEY=

# OPTIONAL. Connect-your-Gmail sending (best cold-email deliverability). Create an
# OAuth client at console.cloud.google.com (scopes: gmail.send + gmail.metadata),
# set the redirect URI to <APP_BASE_URL>/api/oauth/google/callback. Without these,
# Settings still offers a dev "test mailbox" that routes to the in-app outbox.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Per-account daily outreach send cap enforced by the dispatcher (reputation guard).
# Owners can lower their own cap in Settings but never exceed this.
# OUTREACH_DAILY_CAP_MAX=200

# Force the dev outbox transport in a deployed demo environment (never with real users)
# DEV_OUTBOX=1
